blueprint BP_Door : Actor at "/Game/Generated/BP_Door_Gen" {
    @root
    component Root: SceneComponent;

    @attach(Root)
    component Mesh: StaticMeshComponent {
        StaticMesh = asset<StaticMesh>("/Game/Props/SM_Door.SM_Door");
    }

    @editable
    @category("Door")
    var OpenAngle: float = 90.0;

    event BeginPlay() {
        print("Door ready");
    }
}
